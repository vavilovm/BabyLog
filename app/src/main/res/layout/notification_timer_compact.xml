<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <Chronometer
        android:id="@+id/notification_chronometer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="@color/notification_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notification_action_1"
        android:layout_width="60dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/notification_action"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notification_action_2"
        android:layout_width="60dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/notification_action"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notification_action_3"
        android:layout_width="60dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/notification_action"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
